---
import { Image } from 'astro:assets'

import SocialIcons from './SocialIcons.astro'


const {fullName, title, institute, profilePicture} = Astro.props
---
<div class='flex-1'>
  <h1 class='text-4xl font-bold mb-4'>
    Hola! I'm <span class='text-[oklch(51.1%_0.096_186.391)]'>{fullName}</span>
  </h1>
  <p class='text-xl text-gray-600 mb-4'>{title}{institute ? ` at ${institute}` : ''}</p>
  <p class='text-lg mb-6'>
    Cybersecurity is both engineering and decision-making under uncertainty. My work sits at that intersection.
  </p>
  <p class='text-lg mb-6'>
    I turn complex security problems into security systems that are practical, scalable, and resilient by putting people and process before tools.
  </p>
</div>
<div class='size-72 lg:block hidden'>
  <!-- Add your profile image -->
  <Image
    src={profilePicture}
    alt={fullName}
    class='w-full h-full mask mask-circle size-44'
  />
</div>
